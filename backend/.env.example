# Copy this file to .env and fill in your values

# MongoDB connection string
MONGO_URI=mongodb://127.0.0.1:27017/alpr_db

# Express server port
PORT=5000

# Path to Python executable in your virtual environment
# Windows example: PYTHON_EXE=C:\Users\YourName\alpr-project\.venv\Scripts\python.exe
# Linux/macOS example: PYTHON_EXE=/home/yourname/alpr-project/.venv/bin/python
PYTHON_EXE=python
